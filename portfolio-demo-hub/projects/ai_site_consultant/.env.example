APP_NAME=Universal AI Site Consultant
DEBUG=false
UVICORN_WORKERS=1

DATABASE_URL=postgresql+psycopg://postgres:change_me@ai_site_consultant_postgres:5432/ai_consultant

GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
KNOWLEDGE_DIR=/app/knowledge
CHROMA_PATH=/app/chroma_data
CHROMA_COLLECTION=business_knowledge
RAG_MAX_DISTANCE=0.78
ALLOWED_ORIGINS=https://your-domain.com

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_SESSION_SECRET=change_me_long_random_string
ADMIN_COOKIE_SECURE=true

LEAD_RETENTION_DAYS=14

# Optional email settings for standalone AI_Chat_Web. Portfolio Hub does not send email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=
