# Этот файл содержит пример переменных окружения для локального запуска приложения.
APP_NAME=Universal AI Site Consultant
DEBUG=true
UVICORN_WORKERS=1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_consultant

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
KNOWLEDGE_DIR=knowledge
CHROMA_PATH=chroma_data
CHROMA_COLLECTION=business_knowledge
RAG_MAX_DISTANCE=0.78
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Данные используются только при первом создании администратора.
# После смены в /admin/settings значения хранятся в PostgreSQL и не
# перезаписываются из .env.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Длинный случайный секрет для подписи cookie-сессии.
ADMIN_SESSION_SECRET=change_me_long_random_string

# В production с HTTPS установите true.
ADMIN_COOKIE_SECURE=false

# Срок хранения заявок и связанных диалогов в PostgreSQL.
# После 14 дней данные автоматически удаляются полностью.
LEAD_RETENTION_DAYS=14

# SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD и EMAIL_FROM -
# техническая почта системы. Эти параметры один раз настраивает владелец
# системы. Клиенту не нужно передавать SMTP-логин или пароль.
#
# EMAIL_TO - единственная email-переменная, которая меняется для клиента.
# В ней указывается почта клиента, куда должны приходить новые заявки.
#
# Если технический SMTP пока не настроен, оставьте SMTP_HOST, SMTP_USER,
# SMTP_PASSWORD и EMAIL_FROM пустыми. Лид все равно сохранится в PostgreSQL,
# приложение не упадет, а ошибка отправки будет записана в лог.

# Адрес SMTP-сервера технической почты системы, например smtp.gmail.com.
SMTP_HOST=smtp.gmail.com

# Порт технического SMTP-сервера, обычно 587.
SMTP_PORT=587

# Логин технической почты системы.
SMTP_USER=smtp.gmail.com

# Пароль или пароль приложения технической почты системы.
SMTP_PASSWORD=

# Использовать защищенное соединение TLS.
SMTP_USE_TLS=true

# Адрес отправителя - техническая почта системы.
EMAIL_FROM=

# Почта клиента, куда должны приходить новые заявки.
# При подключении нового клиента изменяется только это значение.
EMAIL_TO=
